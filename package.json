{
  "name": "flyto-docs",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "node scripts/audit-docs-public.mjs",
    "lint": "node --check scripts/check-public-links.mjs && node --check scripts/list-external-links.mjs && node scripts/audit-docs-public.mjs",
    "audit:seo": "node scripts/audit-seo-surface.mjs",
    "check:links": "node scripts/check-public-links.mjs",
    "links:external": "node scripts/list-external-links.mjs",
    "build": "vitepress build",
    "verify": "npm run test && npm run lint && npm run build && npm run check:links && npm run audit:seo",
    "docs:dev": "vitepress dev",
    "docs:build": "npm run build",
    "docs:preview": "vitepress preview"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  },
  "overrides": {
    "vite": "6.4.3",
    "esbuild": "0.25.12",
    "postcss": ">=8.5.10"
  }
}
