# Flyto2 Docs does not require secrets for local build or public publishing.
#
# Optional public-only site metadata can be set by deployment systems. Never put
# API keys, customer data, Firebase credentials, or private tunnel URLs here.

VITE_FLYTO_DOCS_SITE_URL=https://docs.flyto2.com
VITE_FLYTO_PRODUCT_URL=https://flyto2.com

